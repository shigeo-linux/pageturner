[Desktop Entry]
Version=1.0
Type=Application
Name=Pageturner
GenericName=Book Reader
Comment=EPUB and PDF reader with dark mode and reading progress
Exec=/opt/pageturner/venv/bin/python3 /opt/pageturner/pageturner.py %u
Icon=/opt/pageturner/pageturner.svg
StartupWMClass=com.pageturner.app
Terminal=false
Categories=Office;Viewer;
Keywords=epub;pdf;ebook;reader;
StartupNotify=true
